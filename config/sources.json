{
  "sources": [
    {
      "name": "purchase_inbound",
      "title": "供货明细查询 / 采购入库",
      "flow_order": 1,
      "type": "excel_export",
      "url_secret": "CMMS_PURCHASE_INBOUND_URL",
      "default_url": "http://103.14.132.165:8068/ECOERP_CMMS/webserch/web_mjc_0008/?id=1846",
      "output_dir": "data/excel_export/purchase_inbound",
      "date_filter": {
        "field_label": "业务时间",
        "input_format": "YYYY-MM-DD/YYYY-MM-DD",
        "default_lookback_days": 3,
        "manual_example": "2026-05-21/2026-05-23"
      },
      "export_button_text": "导出Excel",
      "download_filename": "供货明细查询.xls",
      "notes": "供应链流动第一步：采购入库。支持按业务时间筛选，格式为 YYYY-MM-DD/YYYY-MM-DD，点击 导出Excel 下载 xls。"
    },
    {
      "name": "defective_tracking",
      "title": "不良品跟踪",
      "flow_order": 5,
      "type": "excel_export",
      "url_secret": "CMMS_DEFECTIVE_TRACKING_URL",
      "default_url": "http://103.14.132.165:8068/ECOERP_CMMS/webserch/web_mjc_0004/?id=1839",
      "output_dir": "data/excel_export/defective_tracking",
      "date_filter": null,
      "query_button_selector": "#Button2",
      "export_button_text": "导出Excel",
      "download_filename": "不良品跟踪.xls",
      "notes": "操作流程与其他 Excel 导出页面一致：先点击开始查询，再点击导出Excel。"
    },
    {
      "name": "post_process_report_tracking",
      "title": "后工序报工跟踪",
      "flow_order": 6,
      "type": "excel_export",
      "url_secret": "CMMS_POST_PROCESS_REPORT_TRACKING_URL",
      "default_url": "http://103.14.132.165:8068/ECOERP_CMMS/webserch/web_mjc_0008/?id=1876",
      "output_dir": "data/excel_export/post_process_report_tracking",
      "date_filter": {
        "field_label": "时间型",
        "selector": "#text0",
        "input_format": "YYYY-MM-DD/YYYY-MM-DD",
        "default_lookback_days": 3,
        "manual_example": "2026-05-21/2026-05-23"
      },
      "query_button_selector": "#Button2",
      "export_button_text": "导出Excel",
      "download_filename": "后工序报工跟踪.xls",
      "notes": "按 text0 时间范围筛选，点击开始查询后导出 Excel。"
    }
